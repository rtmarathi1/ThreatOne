<?xml version="1.0" encoding="UTF-8"?>
<Installer>
    <Name>ThreatOne Enterprise</Name>
    <Version>1.0.0</Version>
    <Title>ThreatOne Enterprise</Title>
    <Publisher>ThreatOne Security Inc</Publisher>
    <StartMenuDir>ThreatOne Enterprise</StartMenuDir>
    <TargetDir>@HomeDir@/ThreatOne</TargetDir>
    <AdminTargetDir>@HomeDir@/ThreatOne</AdminTargetDir>
    <InstallerApplicationIcon>threatone</InstallerApplicationIcon>
    <InstallerWindowIcon>threatone</InstallerWindowIcon>
    <Logo>logo.png</Logo>
    <Watermark>watermark.png</Watermark>
    <RunProgram>@TargetDir@/bin/threatone</RunProgram>
    <RunProgramArguments></RunProgramArguments>
    <RunProgramDescription>Launch ThreatOne Enterprise</RunProgramDescription>
    <AllowNonAsciiCharacters>true</AllowNonAsciiCharacters>
    <AllowSpaceInPath>true</AllowSpaceInPath>
    <ControlScript>controller.js</ControlScript>
</Installer>
